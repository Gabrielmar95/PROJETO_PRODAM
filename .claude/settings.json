{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch(domain:www.agenciaamazonas.am.gov.br)",
      "WebFetch(domain:radaramazonico.com.br)",
      "WebFetch(domain:www.detran.am.gov.br)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:sapl.al.am.leg.br)",
      "WebFetch(domain:www.pge.am.gov.br)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$CLAUDE_PROJECT_DIR\\.claude\\hooks\\block_pdf_delete.ps1\"",
            "timeout": 5,
            "statusMessage": "Verificando remoção de PDF..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "command -v python3 >/dev/null 2>&1 && python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/precompact-handoff.py\" || true",
            "timeout": 30,
            "statusMessage": "Snapshot pre-compact (.remember/)"
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "if (Get-Command py -ErrorAction SilentlyContinue) { py -3.12 \"$env:CLAUDE_PROJECT_DIR/.claude/hooks/precompact-handoff.py\" }",
            "timeout": 30,
            "statusMessage": "Snapshot pre-compact (.remember/)"
          }
        ]
      }
    ]
  }
}
