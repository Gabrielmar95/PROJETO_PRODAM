#!/usr/bin/env sh
# S4-M16 — pre-commit hook
# Roda type-check + lint-staged (prettier nos arquivos staged)
# NÃO roda vitest aqui (lento demais para hook); CI faz isso.

echo "[pre-commit] tsc --noEmit"
pnpm check || exit 1

echo "[pre-commit] lint-staged"
pnpm exec lint-staged || exit 1

echo "[pre-commit] OK"
