# Banco de dados (fica so local)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# PDFs e documentos pesados (fica so local)
*.pdf
*.PDF

# Subrepositorios com vida propria (ficam de fora)
PRODAM_DOCS/
SPCF_EXTRACAO/
detran_dashboard/

# Saida do organizador de acervo (copias + manifesto, dezenas de GB — so local)
_ORGANIZADO_*/

# Ferramentas/configs locais (nao versionar)
datadog-agent/
*.code-workspace

# Python
__pycache__/
*.pyc
.venv/
venv/
env/

# Segredos e ambiente
.env
*.key
credentials.json
token.json

# Config local do Claude Code (especifica da maquina; nunca versionar)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Arquivo morto da consolidacao .claude (so local; contem settings.local antigos)
_ARCHIVE_CLAUDE/

# Pacotes de terceiros baixados (vendored) e artefatos de teste — nao versionar
impeccable-main/
awesome-design-md-main/
datadog-agent/
coverage/

# Backups locais de arquivos regenerados
*.bak.*
*.bak-*

# Snapshot automatico do hook PreCompact (regenerado a cada /compact; local-only)
.remember/

# Lixo temporario de sistema
.fuse_hidden*
nul
.DS_Store
Thumbs.db
*.log
*.tmp
node_modules/

# Backups de banco de dados (qualquer .BAK de .db)
*.db.BAK
*.db_*.BAK
*.BAK

# Pastas de saida de sessoes antigas (pesadas)
_ARQUIVO_SESSAO_*/_OUT_*/

# Certificados digitais (ICP-Brasil — NUNCA versionar)
*.pem
*.pfx
*.p12
*.crt
*.cer
*.pkcs12

# Documentos Office (geralmente contêm dados de caso)
# Para versionar um modelo SEM dados reais, use: git add -f caminho/do/modelo.docx
*.docx
*.doc
*.xlsx
*.xls
*.csv

# Índice vetorial (ChromaDB)
chroma/
chromadb/

# Pastas de saída genéricas
outputs/
output/

# claude-mem litter: ignora CLAUDE.md de subpasta; mantém só o canônico da raiz
# (gerado por scripts/auto_update_claude_md.py). Para versionar um sub-CLAUDE real: git add -f caminho
**/CLAUDE.md
!/CLAUDE.md
