"""
detran_auditoria_profunda.py — Auditoria completa do DETRAN/AM.

DETRAN é prioridade #2 do portfolio PRODAM:
  - R$ 31,7M exigível | R$ 38,0M atualizado (IGPM+1%+2%)
  - 233 faturas, 179 exigíveis, 54 prescritas
  - Fase F5 (petição pronta)
  - CRÍTICO: profile marcado como PRESCRITA (D-21) — requer ação imediata

Produz:
  DETRAN_AUDITORIA/
    ├── RELATORIO_DETRAN.md         — relatório legível
    ├── DETRAN_DATASET.json         — dados completos
    ├── DETRAN_FATURAS.csv          — todas as 113 faturas do DB
    ├── DETRAN_EMPENHOS.csv         — 501 NEs
    ├── DETRAN_CONTRATOS.csv        — contratos e NEs por contrato
    ├── DETRAN_CADEIA.csv           — cadeia 5 elos por fatura
    ├── DETRAN_PRESCRICAO.csv       — análise fatura-a-fatura com marco interruptivo
    ├── dashboard.html              — visual Chart.js
"""
from __future__ import annotations
import json, sys, sqlite3, csv
from pathlib import Path
from datetime import date, datetime, timedelta
from decimal import Decimal
from collections import defaultdict, Counter

sys.stdout.reconfigure(encoding='utf-8')
ROOT = Path(__file__).parent.parent.parent
sys.path.insert(0, str(ROOT))
sys.path.insert(0, str(ROOT / "scripts"))
from prodam_utils import (
    norm, norm_variants, brl, fmt_brl, parse_br_date, parse_comp,
    esta_prescrita, load_profiles
)

DB = sqlite3.connect(str(ROOT / "prodam.db"))
DB.row_factory = sqlite3.Row
OUT = ROOT / "DETRAN_AUDITORIA"
OUT.mkdir(exist_ok=True)

HOJE = date.today()
CUTOFF = HOJE - timedelta(days=365*5)

# ============================================================
# 1) LOAD PROFILE
# ============================================================
profiles = json.load(open(ROOT / "PRODAM_DOCS" / "profiles.json", encoding='utf-8'))
detran = profiles["DETRAN"]
print(f"[1] Profile DETRAN carregado — {len(detran)} campos")
print(f"    Val exig:      {fmt_brl(detran.get('val_exig'))}")
print(f"    Val atualizado:{fmt_brl(detran.get('val_atualizado'))}")
print(f"    Faturas:       {detran.get('faturas_total')} total ({detran.get('faturas_exigiveis')} exig + {detran.get('faturas_prescritas')} presc)")
print(f"    Status:        {detran.get('status')} | Fase: {detran.get('fase_atual')}")
print(f"    Prescrição:    {detran.get('data_prescricao_proxima')} (D{detran.get('d_plus_prescricao')})")

# ============================================================
# 2) DB DATA
# ============================================================
contratos = [dict(r) for r in DB.execute("""
    SELECT id, numero, cliente, dados_base
    FROM spcf_contratos
    WHERE UPPER(json_extract(dados_base,'$.cliente')) LIKE '%DETRAN%'
    ORDER BY numero
""").fetchall()]
print(f"\n[2] Contratos DETRAN no DB: {len(contratos)}")

empenhos = [dict(r) for r in DB.execute("""
    SELECT id, numero, cliente, contrato_ref, valor, situacao, data_emissao,
           json_extract(dados_base, '$.Descrição') as descricao
    FROM spcf_empenhos
    WHERE cliente = 'DETRAN'
    ORDER BY data_emissao DESC
""").fetchall()]
print(f"    Empenhos: {len(empenhos)} NEs, R$ {sum(float(e['valor'] or 0) for e in empenhos):,.2f}")

faturas = [dict(r) for r in DB.execute("""
    SELECT id, nf, cliente, contrato_num, valor_bruto, competencia, situacao,
           cadeia_completude, cadeia_elos, total_empenhos_vinculados,
           json_extract(fatura_parsed, '$.data_emissao') as data_emissao,
           json_extract(fatura_parsed, '$.valor_servicos') as valor_servico
    FROM spcf_faturas
    WHERE cliente = 'DETRAN'
    ORDER BY valor_bruto DESC
""").fetchall()]
print(f"    Faturas:  {len(faturas)} no DB, R$ {sum(float(f['valor_bruto'] or 0) for f in faturas):,.2f}")

# Convert cadeia_elos JSON string
for f in faturas:
    if f["cadeia_elos"] and isinstance(f["cadeia_elos"], str):
        try: f["cadeia_elos"] = json.loads(f["cadeia_elos"])
        except: f["cadeia_elos"] = {}

# ============================================================
# 3) NE mais recente por contrato (marco interruptivo Art.202 VI CC)
# ============================================================
ne_mais_recente_por_contrato = {}
for e in empenhos:
    contrato = (e.get("contrato_ref") or "").strip()
    if not contrato:
        # Tentar extrair de dados_base
        import json as _j
        try:
            dbase = _j.loads(DB.execute("SELECT dados_base FROM spcf_empenhos WHERE id=?", (e["id"],)).fetchone()["dados_base"])
            contrato = (dbase.get("Contrato") or dbase.get("Convenio") or "").strip()
        except: pass
    if not contrato: contrato = "(sem contrato)"

    data = parse_br_date(e.get("data_emissao"))
    if not data: continue
    existing = ne_mais_recente_por_contrato.get(contrato)
    if not existing or data > existing["data"]:
        ne_mais_recente_por_contrato[contrato] = {
            "data": data,
            "numero": e["numero"],
            "valor": float(e["valor"] or 0),
        }

print(f"\n[3] NEs por contrato (marcos interruptivos): {len(ne_mais_recente_por_contrato)} contratos")
for c, d in sorted(ne_mais_recente_por_contrato.items(), key=lambda x: -x[1]["data"].toordinal())[:10]:
    status = "🟢 INTERROMPE" if d["data"] >= CUTOFF else "🔴 PRESCRITO"
    print(f"    {status} {c:<25} Último NE: {d['data'].isoformat()} ({d['numero']})")

# ============================================================
# 4) Prescrição fatura-a-fatura
# ============================================================
def fatura_esta_protegida(fatura: dict) -> tuple[bool, str]:
    """Uma fatura está protegida se há NE no mesmo contrato após seu vencimento."""
    comp = parse_comp(fatura.get("competencia"))
    if not comp:
        return True, "sem_competencia"
    # Vencimento estimado = comp + 30 dias
    venc = comp + timedelta(days=30)
    contrato = fatura.get("contrato_num", "").strip()
    # NE mais recente nesse contrato
    ne_info = ne_mais_recente_por_contrato.get(contrato)
    if not ne_info:
        # Tentar normalizar nome do contrato
        for k in ne_mais_recente_por_contrato:
            if norm(k) == norm(contrato) or contrato in k or k in contrato:
                ne_info = ne_mais_recente_por_contrato[k]
                break
    if not ne_info:
        prescrita = esta_prescrita(venc)
        return (not prescrita, "sem_ne_conhecida" if not prescrita else "prescrita_sem_ne")
    ne_data = ne_info["data"]
    if ne_data >= venc:
        # Marco interruptivo
        # Prescrição reinicia (pela metade para Fazenda Pública = 2,5 anos)
        nova_data = ne_data + timedelta(days=int(365*2.5))
        if nova_data >= HOJE:
            return True, f"interrompida_por_{ne_info['numero']}"
        else:
            return False, f"reiniciada_mas_prescrita_novamente_pos_{ne_info['numero']}"
    else:
        # NE anterior ao vencimento — não interrompe essa fatura
        prescrita = esta_prescrita(venc)
        return (not prescrita, "ne_anterior_ao_venc")

analise_prescricao = []
for f in faturas:
    protegida, motivo = fatura_esta_protegida(f)
    analise_prescricao.append({
        "id": f["id"],
        "nf": f["nf"],
        "contrato": f["contrato_num"],
        "comp": f["competencia"],
        "valor": float(f["valor_bruto"] or 0),
        "situacao": f["situacao"],
        "cadeia": f["cadeia_completude"],
        "protegida": protegida,
        "motivo": motivo,
    })

prot_sim = [a for a in analise_prescricao if a["protegida"]]
prot_nao = [a for a in analise_prescricao if not a["protegida"]]
val_prot = sum(a["valor"] for a in prot_sim)
val_prescrito = sum(a["valor"] for a in prot_nao)
print(f"\n[4] Prescrição fatura-a-fatura (113 faturas DB)")
print(f"    Protegidas:   {len(prot_sim)} × {fmt_brl(val_prot)}")
print(f"    Prescritas:   {len(prot_nao)} × {fmt_brl(val_prescrito)}")

# ============================================================
# 5) CADEIA DOCUMENTAL (5 elos)
# ============================================================
cadeia_counter = Counter(f["cadeia_completude"] for f in faturas if f["cadeia_completude"])
print(f"\n[5] Cadeia documental:")
for c, n in cadeia_counter.most_common():
    print(f"    {c!r:<20} {n}")

# ============================================================
# 6) ATUALIZAÇÃO MONETÁRIA (IGPM+1%+2% — aproximação)
# ============================================================
# IGPM médio 2020-2026 ~7% a.a (alta) — simplificado
# Fórmula DETRAN: val_atualizado = val_bruto × (1+IGPM/100)^anos × (1+juros_mensais*meses)
def atualizar_detran(valor_bruto: float, comp_str: str) -> dict:
    """Atualiza valor usando IGPM médio + 1% a.m. + multa 2%"""
    comp = parse_comp(comp_str)
    if not comp or valor_bruto <= 0:
        return {"atualizado": valor_bruto, "correcao": 0, "juros": 0, "multa": 0}
    meses = (HOJE.year - comp.year) * 12 + (HOJE.month - comp.month)
    anos = meses / 12
    # IGPM acumulado aprox (média 7% a.a. composto)
    correcao_igpm = valor_bruto * ((1.07 ** anos) - 1)
    # Juros 1% a.m. sobre saldo corrigido (simples)
    valor_corrigido = valor_bruto + correcao_igpm
    juros = valor_corrigido * 0.01 * meses
    # Multa única 2% sobre saldo corrigido
    multa = valor_corrigido * 0.02
    atualizado = valor_corrigido + juros + multa
    return {
        "bruto": valor_bruto,
        "correcao_igpm": correcao_igpm,
        "juros_1pct_am": juros,
        "multa_2pct": multa,
        "atualizado": atualizado,
        "meses_atraso": meses,
    }

# Top 10 faturas atualizadas
atualizacoes = []
for f in sorted(faturas, key=lambda x: -(float(x["valor_bruto"] or 0)))[:30]:
    upd = atualizar_detran(float(f["valor_bruto"] or 0), f["competencia"])
    upd["id"] = f["id"]
    atualizacoes.append(upd)

total_bruto = sum(float(f["valor_bruto"] or 0) for f in faturas)
# Aproximação agregada
meses_medio = sum((HOJE.year - parse_comp(f["competencia"]).year if parse_comp(f["competencia"]) else 0) * 12
                  + (HOJE.month - parse_comp(f["competencia"]).month if parse_comp(f["competencia"]) else 0)
                  for f in faturas if parse_comp(f["competencia"])) / max(1, len(faturas))
total_atualizado = sum(atualizar_detran(float(f["valor_bruto"] or 0), f["competencia"])["atualizado"]
                       for f in faturas)
fator = total_atualizado / total_bruto if total_bruto else 0

print(f"\n[6] Atualização IGPM+1%+2%:")
print(f"    Meses médio atraso: {meses_medio:.1f}")
print(f"    Bruto:       {fmt_brl(total_bruto)}")
print(f"    Atualizado:  {fmt_brl(total_atualizado)}")
print(f"    Fator médio: {fator:.2f}×")

# ============================================================
# 7) BLINDAGEM PRÉ-EXECUÇÃO (6 blocos Art.784 CPC)
# ============================================================
blindagem = {
    "titulo_executivo": {
        "requisito": "Art.784 CPC — instrumento público/particular",
        "evidencia": "Contratos formais assinados (228 SPCF)",
        "ok": len(contratos) > 0,
    },
    "liquidez": {
        "requisito": "Valor líquido, certo, exigível (Art.783 CPC)",
        upd["comp"] = f["competencia"]
    a"evidencia": f"Valor bruto agregado R$ {total_bruto:,.2f} do SPCF",
        "ok": total_bruto > 0,
    },
    "cadeia_documental": {
        "requisito": "REsp 793.969/RJ — Contrato+NE+NF+Atesto",
        "evidencia": f"{cadeia_counter.get('COMPLETA',0)+cadeia_counter.get('FORTE',0)} faturas com cadeia FORTE/COMPLETA",
        "ok": (cadeia_counter.get("COMPLETA",0)+cadeia_counter.get("FORTE",0)) >= 80,
    },
    "prescricao": {
        "requisito": "Não prescrita + marcos Art.202 VI",
        "evidencia": f"{len(prot_sim)} faturas protegidas × R$ {val_prot:,.2f}",
        "ok": len(prot_sim) > 0,
        "atencao": f"ATENÇÃO: profile marca urgencia_prescricao=PRESCRITA (D{detran.get('d_plus_prescricao')}) — verificar Of.129/2021",
    },
    "reconhecimento_tacito": {
        "requisito": "Art.202 VI CC — empenho é reconhecimento",
        "evidencia": f"{len(empenhos)} NEs, {len(ne_mais_recente_por_contrato)} contratos com NE posterior a vencimento",
        "ok": len(empenhos) > 50,
    },
    "inadimplemento": {
        "requisito": "Mora ex re (Art.397 CC)",
        "evidencia": f"padrão {detran.get('padrao_inadimplencia')}, início {detran.get('inicio_inadimplencia')}",
        "ok": True,
    },
}
print(f"\n[7] Blindagem pré-execução:")
for k, v in blindagem.items():
    emoji = "✅" if v["ok"] else "⚠️"
    print(f"    {emoji} {k}: {v['evidencia']}")

# ============================================================
# 8) EXPORTS
# ============================================================
# JSON completo
dataset = {
    "meta": {
        "data": HOJE.isoformat(),
        "cutoff_prescricao_base": CUTOFF.isoformat(),
        "fonte_profile": "profiles.json (154 campos)",
    },
    "profile": detran,
    "contratos_db_count": len(contratos),
    "empenhos_db": {
        "count": len(empenhos),
        "valor_total": sum(float(e['valor'] or 0) for e in empenhos),
    },
    "faturas_db": {
        "count": len(faturas),
        "valor_bruto": total_bruto,
        "valor_atualizado": total_atualizado,
        "fator_igpm_juros_multa": fator,
    },
    "ne_mais_recente_por_contrato": {k: {"data": v["data"].isoformat(), "numero": v["numero"], "valor": v["valor"]}
                                      for k, v in ne_mais_recente_por_contrato.items()},
    "prescricao": {
        "total": len(analise_prescricao),
        "protegidas": len(prot_sim),
        "prescritas": len(prot_nao),
        "valor_protegido": val_prot,
        "valor_prescrito": val_prescrito,
    },
    "cadeia_distribuicao": dict(cadeia_counter),
    "blindagem": blindagem,
    "top30_atualizacoes": atualizacoes,
    "faturas_prescritas_amostra": [a for a in analise_prescricao if not a["protegida"]][:20],
}
json.dump(dataset, open(OUT / "DETRAN_DATASET.json", "w", encoding="utf-8"), ensure_ascii=False, indent=2, default=str)
print(f"\n[8] Exports em {OUT}/")
print("    - DETRAN_DATASET.json")

# CSVs
def write_csv(path, rows, headers):
    with open(path, "w", encoding="utf-8-sig", newline="") as f:
        w = csv.writer(f, delimiter=";")
        w.writerow(headers)
        for r in rows:
            w.writerow([str(r.get(h, "")).replace(".",",") if isinstance(r.get(h),(int,float)) else r.get(h,"") for h in headers])

write_csv(OUT / "DETRAN_FATURAS.csv",
          faturas,
          ["id","nf","contrato_num","competencia","valor_bruto","situacao","cadeia_completude","total_empenhos_vinculados"])
write_csv(OUT / "DETRAN_EMPENHOS.csv",
          empenhos,
          ["id","numero","contrato_ref","valor","situacao","data_emissao","descricao"])
write_csv(OUT / "DETRAN_PRESCRICAO.csv",
          analise_prescricao,
          ["id","nf","contrato","comp","valor","situacao","cadeia","protegida","motivo"])
print("    - DETRAN_FATURAS.csv / DETRAN_EMPENHOS.csv / DETRAN_PRESCRICAO.csv")
